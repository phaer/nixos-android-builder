From 6d2c375ac0de9ea60684481e59ae627a842b10cf Mon Sep 17 00:00:00 2001
From: phaer <phaer@phaer.org>
Date: Wed, 25 Mar 2026 17:49:34 +0100
Subject: [PATCH 2/3] tpm: use policy's relevant PCRs for event log
 verification

Intersect MEASUREDBOOT_PCRS with the active policy's
get_relevant_pcrs() set for the PCR replay check. PCRs outside
the policy's set may have runtime extensions not in the event
log (e.g. PCR 11 from systemd-pcrphase).

This is backwards compatible: policies that return all PCRs (or
an empty set) behave as before.

Signed-off-by: phaer <phaer@phaer.org>
---
 keylime/tpm/tpm_main.py | 18 +++++++++++++++++-
 1 file changed, 17 insertions(+), 1 deletion(-)

diff --git a/keylime/tpm/tpm_main.py b/keylime/tpm/tpm_main.py
index 0f68c26..b8e4300 100644
--- a/keylime/tpm/tpm_main.py
+++ b/keylime/tpm/tpm_main.py
@@ -16,6 +16,7 @@ from keylime.ima import ima
 from keylime.ima.file_signatures import ImaKeyrings
 from keylime.ima.types import RuntimePolicyType
 from keylime.mba import mba
+from keylime.mba.elchecking import policies as mb_policies
 from keylime.tpm import tpm2_objects, tpm_util
 from keylime.tpm.errors import (
     HashAlgorithmMismatch,
@@ -452,7 +453,22 @@ class Tpm:
                 pass
 
         if not mb_failure and mb_policy is not None and mba.policy_is_valid(mb_policy) and mb_policy_is_nonempty:
-            for pcr_num in set(config.MEASUREDBOOT_PCRS) & pcr_nums:
+            # Intersect MEASUREDBOOT_PCRS (what we can verify against
+            # the event log) with the policy's relevant PCRs (what the
+            # policy cares about).  PCRs outside the policy's set may
+            # have runtime extensions not in the event log (e.g. PCR 11
+            # from systemd-pcrphase).
+            mb_pcr_set = set(config.MEASUREDBOOT_PCRS)
+            mb_policy_name = config.get(
+                "verifier", "measured_boot_policy_name",
+                fallback="accept-all",
+            )
+            mb_policy_obj = mb_policies.get_policy(mb_policy_name)
+            if mb_policy_obj is not None:
+                policy_pcrs = mb_policy_obj.get_relevant_pcrs()
+                if policy_pcrs:
+                    mb_pcr_set = mb_pcr_set & policy_pcrs
+            for pcr_num in mb_pcr_set & pcr_nums:
                 if not mb_measurement_list:
                     logger.error(
                         "Measured Boot PCR %d in policy, but no measurement list provided by agent %s",
