@@ -277,6 +281,100 @@ class TestTPMEngineFreshPolicy(unittest.TestCase):
         # Create engine instance
         self.engine = TPMEngine(self.mock_attestation)
 
+    @patch("keylime.models.base.db_manager.session")
+    def test_uefi_ref_state_bypass_bypasses_cache(self, mock_session):
+        """Test that uefi_ref_state issues raw SQL to bypass both ORM identity maps.
+
+        The mbpolicies table is mapped by two independent SQLAlchemy ORM classes; a raw
+        SELECT is the only way to guarantee the current database value is returned.
+        """
+        fresh_agent = MagicMock()
+        fresh_agent.mb_policy_id = 7
+
+        mock_result = MagicMock()
+        mock_result.fetchone.return_value = ('[{"log": []}]',)
+        mock_session.return_value.execute.return_value = mock_result
+
+        self.engine._fresh_agent = fresh_agent  # pylint: disable=attribute-defined-outside-init
+
+        policy = self.engine.uefi_ref_state
+
+        self.assertEqual(policy, '[{"log": []}]')
+        mock_session.return_value.execute.assert_called_once()
+        call_args = mock_session.return_value.execute.call_args
+        sql_str = str(call_args[0][0]).upper()
+        self.assertIn("SELECT MB_POLICY FROM MBPOLICIES", sql_str)
+        self.assertEqual(call_args[0][1]["policy_id"], 7)
+
+    def test_uefi_ref_state_uses_cached_when_no_fresh_agent(self):
+        """Test that uefi_ref_state falls back to the ORM value when no fresh agent is available."""
+        self.mock_agent.mb_policy = MagicMock()
+        self.mock_agent.mb_policy.mb_policy = "cached-policy"
+
+        policy = self.engine.uefi_ref_state
+
+        self.assertEqual(policy, "cached-policy")
+
+    def test_uefi_ref_state_uses_cached_when_fresh_agent_has_no_policy_id(self):
+        """Test that uefi_ref_state falls back to ORM when fresh agent carries no mb_policy_id."""
+        fresh_agent = MagicMock()
+        fresh_agent.mb_policy_id = None
+        # When fresh_agent is set, TPMEngine.agent returns it, so mb_policy must be set there
+        fresh_agent.mb_policy = MagicMock()
+        fresh_agent.mb_policy.mb_policy = "cached-policy"
+        self.engine._fresh_agent = fresh_agent  # pylint: disable=attribute-defined-outside-init
+
+        policy = self.engine.uefi_ref_state
+
+        self.assertEqual(policy, "cached-policy")
+
+    @patch("keylime.models.base.db_manager.session")
+    def test_uefi_ref_state_bypass_bypasses_cache(self, mock_session):
+        """Test that uefi_ref_state issues raw SQL to bypass both ORM identity maps.
+
+        The mbpolicies table is mapped by two independent SQLAlchemy ORM classes; a raw
+        SELECT is the only way to guarantee the current database value is returned.
+        """
+        fresh_agent = MagicMock()
+        fresh_agent.mb_policy_id = 7
+
+        mock_result = MagicMock()
+        mock_result.fetchone.return_value = ('[{"log": []}]',)
+        mock_session.return_value.execute.return_value = mock_result
+
+        self.engine._fresh_agent = fresh_agent  # pylint: disable=attribute-defined-outside-init
+
+        policy = self.engine.uefi_ref_state
+
+        self.assertEqual(policy, '[{"log": []}]')
+        mock_session.return_value.execute.assert_called_once()
+        call_args = mock_session.return_value.execute.call_args
+        sql_str = str(call_args[0][0]).upper()
+        self.assertIn("SELECT MB_POLICY FROM MBPOLICIES", sql_str)
+        self.assertEqual(call_args[0][1]["policy_id"], 7)
+
+    def test_uefi_ref_state_uses_cached_when_no_fresh_agent(self):
+        """Test that uefi_ref_state falls back to the ORM value when no fresh agent is available."""
+        self.mock_agent.mb_policy = MagicMock()
+        self.mock_agent.mb_policy.mb_policy = "cached-policy"
+
+        policy = self.engine.uefi_ref_state
+
+        self.assertEqual(policy, "cached-policy")
+
+    def test_uefi_ref_state_uses_cached_when_fresh_agent_has_no_policy_id(self):
+        """Test that uefi_ref_state falls back to ORM when fresh agent carries no mb_policy_id."""
+        fresh_agent = MagicMock()
+        fresh_agent.mb_policy_id = None
+        # When fresh_agent is set, TPMEngine.agent returns it, so mb_policy must be set there
+        fresh_agent.mb_policy = MagicMock()
+        fresh_agent.mb_policy.mb_policy = "cached-policy"
